// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum SubscriptionStatus {
  FREE
  ACTIVE
}

// Category model for dynamic categorization
model Category {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  description String?
  type        CategoryType
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // Relations
  recipes   Recipe[]
  blogPosts BlogPost[]

  @@index([type])
  @@map("categories")
}

enum CategoryType {
  RECIPE
  BLOG
}

// User model for authentication
model User {
  id                  String             @id @default(cuid())
  email               String             @unique
  password            String // bcrypt hashed
  name                String
  whatsapp            String?
  role                Role               @default(USER)
  subscriptionStatus  SubscriptionStatus @default(FREE)
  subscriptionEndDate DateTime?

  abacateCustomerId String? @unique

  birthdate DateTime

  username  String?  @unique
  avatarUrl String?
  weight    Float?   // kg
  height    Int?     // cm

  // Profile — social & privacy
  bio           String?
  instagram     String?
  twitter       String?
  youtube       String?
  tiktok        String?
  linkedin      String?
  website       String?
  profilePublic Boolean @default(true)

  emailVerified            DateTime?
  verificationToken        String?   @unique
  verificationTokenExpires DateTime?
  resetToken               String?   @unique
  resetTokenExpiry         DateTime?

  pendingEmail              String?
  emailChangeToken          String?   @unique
  emailChangeTokenExpires   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Gamification
  xp    Int @default(0)
  level Int @default(1)

  // Relations
  recipes         Recipe[]
  blogPosts       BlogPost[]
  enrollments     CourseEnrollment[]
  transactions    Transaction[]
  activityLogs    ActivityLog[]
  lessonComments  LessonComment[]
  fastingSessions FastingSession[]
  notifications   Notification[]
  forumPosts      ForumPost[]
  forumReplies    ForumReply[]
  postLikes       PostLike[]
  userBadges      UserBadge[]

  @@map("users")
}

// Recipe model
model Recipe {
  id          String           @id @default(cuid())
  title       String
  slug        String           @unique
  description String
  content     String           @db.Text
  coverImage  String? // Renamed from imageUrl for consistency
  tags        String[]         @default([]) // For filtering and SEO
  prepTime    Int? // in minutes
  cookTime    Int? // in minutes
  servings    Int?
  difficulty  RecipeDifficulty @default(MEDIUM)
  cuisine     String?

  // Nutrition info
  calories       Int?
  macronutrients Json? // { protein: number, fat: number, carbs: number }
  // Legacy fields (kept for backward compatibility)
  protein        Int?
  fat            Int?
  carbs          Int?

  // SEO
  metaTitle       String?
  metaDescription String?
  coverImageAlt   String?

  // Rich Snippets (Google Search Console)
  ratingValue Float? // aggregateRating.ratingValue (ex: 4.9)
  ratingCount Int?   // aggregateRating.ratingCount (ex: 203)

  // Metadata
  published Boolean  @default(false)
  featured  Boolean  @default(false)
  isPremium Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  authorId     String
  author       User                @relation(fields: [authorId], references: [id], onDelete: Cascade)
  categoryId   String?
  category     Category?           @relation(fields: [categoryId], references: [id])
  ingredients  RecipeIngredient[]
  instructions RecipeInstruction[]

  @@index([categoryId])
  @@index([published])
  @@index([featured])
  @@map("recipes")
}

enum RecipeDifficulty {
  EASY
  MEDIUM
  HARD
}

model RecipeIngredient {
  id       String @id @default(cuid())
  recipeId String
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  name     String
  amount   String
  order    Int

  @@index([recipeId])
  @@map("recipe_ingredients")
}

model RecipeInstruction {
  id       String @id @default(cuid())
  recipeId String
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  step     Int
  content  String @db.Text
  name     String?  // "Passo 1" — override do auto-gerado no JSON-LD
  image    String?  // Imagem por passo (fallback: coverImage da receita)
  video    String?  // Video por passo (opcional)

  @@index([recipeId])
  @@map("recipe_instructions")
}

// Offer banner to show inside a blog post
enum BlogOfferBanner {
  AUTO        // detecta pela categoria/tags (padrão)
  LIVRO       // Manual da Cozinha Ancestral
  JEJUM       // Guia do Jejum Intermitente
  TESTO       // Testosterona Primal
  MEMBERSHIP  // Assinatura Premium
  NONE        // sem banner
}

// Blog Post model
model BlogPost {
  id         String   @id @default(cuid())
  title      String
  slug       String   @unique
  excerpt    String // Short description for SEO
  content    String   @db.Text
  coverImage String? // Renamed from imageUrl for consistency
  tags       String[] @default([]) // For filtering and SEO
  readTime   Int // in minutes

  // SEO
  metaTitle       String?
  metaDescription String?
  coverImageAlt   String?

  // Monetização
  offerBanner BlogOfferBanner @default(AUTO)

  // Metadata
  published   Boolean   @default(false)
  featured    Boolean   @default(false)
  isPremium   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  authorId   String
  author     User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  @@index([categoryId])
  @@index([published])
  @@index([featured])
  @@map("blog_posts")
}

// Course model
model Course {
  id          String  @id @default(cuid())
  title       String
  slug        String  @unique
  description String  @db.Text
  coverImage  String?
  isPremium   Boolean @default(true)

  // Pricing & Payment
  price           Int?    // em centavos (ex: 4900 = R$ 49,00). null = acesso por assinatura
  kiwifyUrl       String? // URL de checkout Kiwify (ex: https://pay.kiwify.com.br/XXXXX)
  kiwifyProductId String? // ID do produto Kiwify (ex: XXXXX) — extraído da URL para o webhook

  // Lista de Espera
  waitlistEnabled Boolean @default(false) // exibe formulário de lista de espera na página pública

  // SEO
  metaTitle       String?
  metaDescription String?
  ogImage         String? // URL dedicada para Open Graph (redes sociais); fallback: coverImage
  coverImageAlt   String?

  // Metadata
  published Boolean  @default(false)
  featured  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  modules     Module[]
  enrollments CourseEnrollment[]
  waitlist    CourseWaitlist[]

  @@index([published])
  @@index([featured])
  @@index([isPremium])
  @@map("courses")
}

model Module {
  id       String @id @default(cuid())
  title    String
  order    Int
  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  lessons Lesson[]

  @@index([courseId])
  @@map("modules")
}

model Lesson {
  id       String  @id @default(cuid())
  title    String
  slug     String
  videoUrl String? // YouTube/Vimeo/Panda embed URL
  content  String? @db.Text // Rich text for summaries
  order    Int
  isFree   Boolean @default(false) // Free preview lessons

  // SEO
  metaTitle       String?
  metaDescription String?

  moduleId String
  module   Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  progress UserProgress[]
  comments LessonComment[]

  @@unique([moduleId, slug])
  @@index([moduleId])
  @@map("lessons")
}

model CourseEnrollment {
  id       String @id @default(cuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  // How this enrollment was created:
  //   SUBSCRIPTION  → via active membership plan (default)
  //   PAID          → one-time purchase via Kiwify
  //   MANUAL_FREE   → granted by an admin (cortesia / parceria)
  accessType  String  @default("SUBSCRIPTION")
  grantedById String? // Admin user.id who manually granted this access

  enrolledAt  DateTime  @default(now())
  completedAt DateTime?

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@index([accessType])
  @@map("course_enrollments")
}

model CourseWaitlist {
  id        String   @id @default(cuid())
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  name      String
  email     String
  createdAt DateTime @default(now())

  @@unique([courseId, email])
  @@index([courseId])
  @@map("course_waitlist")
}

model UserProgress {
  id          String  @id @default(cuid())
  userId      String
  lessonId    String
  lesson      Lesson  @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  isCompleted Boolean @default(false)

  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
  @@map("user_progress")
}

model LessonComment {
  id        String   @id @default(cuid())
  text      String   @db.Text
  createdAt DateTime @default(now())

  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId String
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  // Thread / nested replies
  parentId String?
  parent   LessonComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  LessonComment[] @relation("CommentReplies")

  @@index([lessonId])
  @@index([userId])
  @@index([parentId])
  @@map("lesson_comments")
}

// Newsletter Subscriber model for lead capture
model NewsletterSubscriber {
  id           String           @id @default(cuid())
  email        String           @unique
  source       NewsletterSource @default(OTHER)
  tags         String[]         @default([]) // Interest tags for segmentation
  active       Boolean          @default(true)
  subscribedAt DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([email])
  @@index([active])
  @@map("newsletter_subscribers")
}

enum NewsletterSource {
  BLOG_FOOTER
  RECIPE_POPUP
  INLINE_CTA
  HOMEPAGE
  LEAD_MAGNET
  OTHER
}

// Transaction model for payment tracking
model Transaction {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  billingId  String  @unique // ID retornado pelo gateway (AbacatePay order ID, Kiwify order_id)
  amount     Int // Valor em centavos
  frequency  String // 'monthly', 'yearly', 'one_time'
  status     String // 'PENDING', 'PAID', 'FAILED', 'CANCELED'
  paymentUrl String? // Link do pagamento
  source     String  @default("ABACATE") // 'ABACATE' | 'KIWIFY'
  product    String? // 'livro-ancestral' | 'jejum' | 'mensal' | 'anual'

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([billingId])
  @@map("transactions")
}

// Contact messages from the public contact form
model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([read])
  @@index([createdAt])
  @@map("contact_messages")
}

// Activity log for tracking user actions
model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  action    String   // 'LOGIN', 'LOGIN_FAILED', 'PAGE_ACCESS', 'DOWNLOAD', 'PURCHASE', etc
  resource  String?  // 'ebook-livro-ancestral', 'dashboard', '/blog/slug', etc
  metadata  Json?    // Extra data: {ip, userAgent, downloadSize, etc}

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("activity_logs")
}

// Fasting Tracker — jejum intermitente / prolongado
model FastingSession {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  startTime   DateTime
  endTime     DateTime?
  targetHours Int       // e.g. 16 | 24 | 72

  // "ONGOING" | "COMPLETED" | "BROKEN"
  status      String    @default("ONGOING")

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@index([status])
  @@map("fasting_sessions")
}

// ─── Gamification ──────────────────────────────────────────────────────────────

model Badge {
  id            String      @id @default(cuid())
  name          String
  description   String
  icon          String      // lucide icon name e.g. "Flame" or emoji
  requiredHours Int
  order         Int         @default(0)
  userBadges    UserBadge[]

  @@map("badges")
}

model UserBadge {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeId    String
  badge      Badge    @relation(fields: [badgeId], references: [id])
  unlockedAt DateTime @default(now())

  @@unique([userId, badgeId])
  @@index([userId])
  @@map("user_badges")
}

// ─── Forum ─────────────────────────────────────────────────────────────────────

model ForumCategory {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  description String
  icon        String      @default("💬")
  order       Int         @default(0)
  posts       ForumPost[]
  createdAt   DateTime    @default(now())

  @@map("forum_categories")
}

model ForumPost {
  id         String        @id @default(cuid())
  slug       String?       @unique
  title      String
  content    String        @db.Text
  views      Int           @default(0)
  pinned     Boolean       @default(false)

  authorId   String
  author     User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  categoryId String
  category   ForumCategory @relation(fields: [categoryId], references: [id])

  replies    ForumReply[]
  likes      PostLike[]

  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([categoryId])
  @@index([authorId])
  @@index([createdAt])
  @@map("forum_posts")
}

model ForumReply {
  id        String    @id @default(cuid())
  content   String    @db.Text

  postId    String
  post      ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)

  parentId  String?
  parent    ForumReply?  @relation("ReplyThread", fields: [parentId], references: [id], onDelete: SetNull)
  replies   ForumReply[] @relation("ReplyThread")

  createdAt DateTime  @default(now())

  @@index([postId])
  @@index([authorId])
  @@index([parentId])
  @@map("forum_replies")
}

model PostLike {
  id        String    @id @default(cuid())

  postId    String
  post      ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())

  @@unique([postId, userId])
  @@index([postId])
  @@map("post_likes")
}

// ─── Notifications ─────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  title     String
  message   String
  link      String?
  isRead    Boolean  @default(false)
  type      String   // "SYSTEM" | "COURSE" | "POST" | "RECIPE" | "MANUAL"

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}
